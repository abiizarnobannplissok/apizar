{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "SERVER_HOST": "0.0.0.0",
    "SERVER_PORT": "6000"
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  }
}
