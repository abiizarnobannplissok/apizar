# Gemini Gateway Configuration

# Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=6000

# API Key for accessing the gateway
# Clients must pass this in Authorization header (OpenAI) or x-api-key header (Anthropic)
PROXY_API_KEY=a

# Gemini API Settings
GEMINI_API_BASE_URL=https://apis.snowping.eu.cc/api/aichat/gemini

# Logging
LOG_LEVEL=INFO

# Timeout Settings (seconds)
REQUEST_TIMEOUT=60
